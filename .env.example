# Secret Word Cipher — Environment Variables
# Copy this file to .env and fill in your values.
# For Vercel deployment, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# NOTE: These values are also hardcoded in public/js/config.js for the static frontend.
# The anon/publishable key is safe to expose in client-side code.
# NEVER put your service-role (secret) key in config.js or any client-side file.
